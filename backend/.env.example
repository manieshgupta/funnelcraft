# API Server Port
PORT=5000

# PostgreSQL direct connection string (Used by backend & worker)
# Fallback local Docker url: postgres://postgres:password@localhost:5432/ai_content_creator
DATABASE_URL=postgresql://postgres:iamBRAVE@1369@db.oazlyzhpvunmsxpvyszw.supabase.co:5432/postgres

# Redis connection URL (Used by BullMQ queue & worker)
# Fallback local Docker url: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# Supabase Configurations (Production only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Secret key used to decode client JWTs (Get this from Supabase API Dashboard)
SUPABASE_JWT_SECRET=local-jwt-secret-placeholder

# App-Level Embedding Service settings (Needs a consistent key)
EMBEDDING_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small
EMBEDDING_API_URL=https://api.openai.com/v1/embeddings

# SEO Web Search (Serper.dev)
SERPER_API_KEY=
